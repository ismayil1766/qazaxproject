DATABASE_URL=""  # Railway Postgres connection string (postgresql://...)
HOSTNAME="0.0.0.0" # Railway proxy expects 0.0.0.0 bind
PORT="8080"       # Railway default
OTP_SECRET="change-me-very-strong"  # admin email OTP hashing √ľ√ß√ľn
ADMIN_SESSION_SECRET="change-me-separate-admin-session-secret"
ALLOW_ADMIN_KEY_FALLBACK="0"
ADMIN_KEY=""
DEFAULT_CITY=""  # boŇü buraxsan, axtarńĪŇülar h…ôr iki Ňü…ôh…ôr (Qazax, Ańüstafa) √ľzr…ô g√∂st…ôril…ôc…ôk

# Client (browser) t…ôr…ôfd…ô default Ňü…ôh…ôr √ľ√ß√ľn.
# NOTE: NEXT_PUBLIC_* olan d…ôyiŇü…ônl…ôr brauzer…ô √∂t√ľr√ľl√ľr.
NEXT_PUBLIC_DEFAULT_CITY="Qazax"  # elan yerl…ôŇüdir…ônd…ô default se√ßim

# Admin email OTP (SMTP) ‚ÄĒ production-da Brevo v…ô ya SMTP t√∂vsiy…ô olunur.
# Production-da konsol fallback ist…ôs…ôn ALLOW_CONSOLE_EMAIL_FALLBACK=1 et (t√∂vsiy…ô olunmur).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@seher-elanlari.local"

# Email OTP (Brevo API) ‚ÄĒ SMTP yerin…ô istifad…ô ed…ô bil…ôrs…ôn (t√∂vsiy…ô olunur).
# ∆Źg…ôr BREVO_API_KEY set olsa, sistem SMTP-d…ôn …ôvv…ôl Brevo API il…ô g√∂nd…ôr…ôc…ôk.
BREVO_API_KEY=""
BREVO_SENDER_EMAIL=""
BREVO_SENDER_NAME="Ňě…ôh…ôr ElanlarńĪ"

# SMTP yoxlama loglarńĪ (1 = aktiv)
SMTP_DEBUG="0"
ALLOW_CONSOLE_EMAIL_FALLBACK="0"

# B…ôzi SMTP provayderl…ôrd…ô (x√ľsus…ôn Gmail) "from" eyni domen/user olmalńĪdńĪr.
# Problemin olarsa SMTP_FROM-u SMTP_USER il…ô eyni et.

# OTP m√ľdd…ôti (d…ôqiq…ô)
OTP_TTL_MINUTES="10"

# OTP resend limit (seconds)
OTP_RESEND_SECONDS="90"

# Listing TTL (days)
LISTING_TTL_DAYS="30"

# Manual admin VIP default m√ľdd…ôti (g√ľn)
VIP_DAYS="7"
# Manual admin Premium default m√ľdd…ôti (g√ľn)
PREMIUM_DEFAULT_DAYS="30"
# User request paketl…ôri: gun:qiymet,gun:qiymet
VIP_PRICE_PLANS="7:5,15:9,30:15"
PREMIUM_PRICE_PLANS="7:3,15:5,30:9"
PROMOTION_REQUESTS_ENABLED="0"
NEXT_PUBLIC_PROMOTION_REQUESTS_ENABLED="0"

# Admin login (default admin/admin)
# Legacy ADMIN_KEY fallback default olaraq s√∂nd√ľr√ľl√ľb.
ADMIN_USER="admin"
ADMIN_PASS="change-me"  # also accepted as ADMIN_PASSWORD for seeding
ADMIN_PASSWORD=""       # optional: used by prisma seed (fallbacks to ADMIN_PASS)

# Admin MFA
ADMIN_EMAIL=admin@example.com
# 32-byte base64 recommended (openssl rand -base64 32)
ADMIN_MFA_ENC_KEY=

# Uploads (optional): default is inside the app's public/uploads.
# On Railway, files are ephemeral unless you attach a Volume.
# If you add a Volume mounted at /data, set:
# UPLOADS_DIR=/data/uploads
UPLOADS_DIR=

# Optional image processing knobs
IMAGE_MAX_WIDTH="1600"
IMAGE_QUALITY="80"

SITE_URL=https://qazaxproject-production.up.railway.app
NEXT_PUBLIC_SITE_URL=https://qazaxproject-production.up.railway.app
